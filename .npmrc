; Flatten @libp2p/utils to node_modules/@libp2p/utils so the
; patch-package vendored fix under patches/@libp2p+utils+7.1.0.patch
; can find the package at the flat path it expects. End-user npm
; install also flattens by default, so this only matches their
; layout. Remove once libp2p ships the upstream onProgress guard
; (libp2p/js-libp2p#3496) and we drop the local patch.
public-hoist-pattern[]=@libp2p/utils
