# .dockerignore for synapse-node

# Dependencies
node_modules
npm-debug.log
yarn-error.log

# Build artifacts — dist is now built INSIDE the Docker image (multi-stage
# builder runs `npm run build`), so the host's dist/ must NOT leak into the
# build context. A stale host-built dist was the root cause of the silent
# "BidResponder never loaded" bug that left /chat/quote returning
# ALL_BIDS_FAILED with no log on the node.
dist
build
*.tsbuildinfo

# Tests
coverage
.nyc_output

# IDE
.idea
.vscode
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Documentation
README.md
*.md

# Config files
.env
.env.*
!.env.example

# Tests
**/*.test.ts
**/*.spec.ts

# Misc
*.log
